:80 {
	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Content-Security-Policy
	}

	handle /ws* {
		reverse_proxy localhost:{$PORT_WS:41602} {
			flush_interval -1
		}
	}
	handle /api/* {
		reverse_proxy localhost:{$PORT_HTTP:41601}
	}
	handle {
		root * /srv/web/dist
		try_files {path} /index.html
		file_server
		encode gzip zstd
	}
}
