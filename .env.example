# QR-Live 环境变量配置
# 复制此文件为 .env 并根据需要修改

# HTTP API 端口（容器内部）
PORT_HTTP=41601

# WebSocket 端口（容器内部，Caddy 代理到此端口）
PORT_WS=41602

# 通道无上传超时秒数（默认 30 分钟）
CHANNEL_TTL_SECONDS=1800

# 过期通道清理间隔秒数
CLEANUP_INTERVAL_SECONDS=60

# 每通道每秒最大上传次数
UPLOAD_RATE_LIMIT=2

# 每通道最大 WebSocket 观看者数
MAX_VIEWERS_PER_CHANNEL=50

# 每 IP 每分钟最大验证次数
VERIFY_RATE_LIMIT=10

# 上传文本最大字符数
MAX_TEXT_LENGTH=2000

# Caddy 域名（留空使用 localhost / HTTP only）
# 设置为实际域名自动申请 Let's Encrypt HTTPS 证书
CADDY_DOMAIN=

# Let's Encrypt 通知邮箱（仅在设置了 CADDY_DOMAIN 时需要）
CADDY_EMAIL=
